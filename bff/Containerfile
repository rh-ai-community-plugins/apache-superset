ARG BASE_IMAGE="registry.access.redhat.com/ubi9/nodejs-22:latest"

# Build stage
FROM ${BASE_IMAGE} AS builder

COPY --chown=default:root bff/package*.json ./
RUN npm ci

COPY --chown=default:root bff/ .
RUN npm run build

# Production stage
FROM ${BASE_IMAGE}

COPY --from=builder --chown=1001:0 /opt/app-root/src/dist ./dist
COPY --from=builder --chown=1001:0 /opt/app-root/src/node_modules ./node_modules
COPY --from=builder --chown=1001:0 /opt/app-root/src/package.json ./

# Superset Helm sub-chart templates (used by helmRenderer at runtime)
COPY --chown=1001:0 chart/charts/superset/ ./chart-templates/superset/

ENV SUPERSET_CHART_DIR=/opt/app-root/src/chart-templates/superset

EXPOSE 3000

USER 1001:0

CMD ["node", "dist/server.js"]
